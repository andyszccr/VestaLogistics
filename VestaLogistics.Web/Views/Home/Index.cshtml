@{
    ViewData["Title"] = "Inicio";
    var compra = ViewData["TipoCambioCompra"] as decimal? ?? 0;
    var venta = ViewData["TipoCambioVenta"] as decimal? ?? 0;
}

<div class="text-center">
    <h1 class="display-4 vestalog-title">Vesta Logistics</h1>
    <p class="lead vestalog-teal">Sistema SaaS Multitenant de control de inventarios y facturación.</p>
    <div class="row justify-content-center mt-4">
        <div class="col-md-6">
            <div class="card vestalog-card">
                <div class="card-body">
                    <h5 class="card-title vestalog-gold">Tipo de cambio (BCCR)</h5>
                    <p class="mb-0">Compra: <strong>₡@compra.ToString("N2")</strong> &middot; Venta: <strong>₡@venta.ToString("N2")</strong></p>
                </div>
            </div>
        </div>
    </div>
</div>
