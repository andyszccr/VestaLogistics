@model VestaLogistics.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger vestalog-title">Error</h1>
<h2 class="text-danger">Ha ocurrido un error al procesar su solicitud.</h2>
@if (Model?.ShowRequestId ?? false)
{
    <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
}
